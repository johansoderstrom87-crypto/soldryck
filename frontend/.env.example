# Postgres (already configured in Railway)
DATABASE_URL=postgres://...

# Google Places API — för venue-foton i popup.
# Aktivera "Places API (New)" i Google Cloud Console.
# Utan den här nyckeln visas inga foton (gracefull degradation).
GOOGLE_PLACES_API_KEY=

# VAPID-nycklar för Web Push notiser.
# Generera med: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:din@email.se

# Secret för cron-endpoint /api/push/send (POST med Authorization: Bearer $CRON_SECRET)
# Sätt upp Railway cron som pingar /api/push/send varje timme 08-20.
CRON_SECRET=
